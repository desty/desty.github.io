---
// Mermaid diagram support - renders mermaid code blocks as diagrams
---

<script is:inline>
  (function() {
    var codeBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
    if (codeBlocks.length === 0) return;

    var s = document.createElement("script");
    s.type = "module";
    s.textContent = `
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

      var isDark = document.documentElement.classList.contains("dark");
      mermaid.initialize({ startOnLoad: false, theme: isDark ? "dark" : "default" });

      var pres = document.querySelectorAll('pre[data-language="mermaid"]');
      for (var i = 0; i < pres.length; i++) {
        var pre = pres[i];
        var code = pre.querySelector("code");
        if (!code) continue;

        var lines = code.querySelectorAll(".line");
        var text = "";
        for (var j = 0; j < lines.length; j++) {
          text += lines[j].textContent + "\\n";
        }
        if (!text) text = code.textContent || "";

        var div = document.createElement("div");
        div.id = "mermaid-diagram-" + i;
        pre.replaceWith(div);

        try {
          var result = await mermaid.render("mermaid-svg-" + i, text.trim());
          div.innerHTML = result.svg;
        } catch (e) {
          div.innerHTML = "<pre style='color:red'>Mermaid Error: " + e + "</pre>";
        }
      }
    `;
    document.body.appendChild(s);
  })();
</script>
