---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import SearchCollection from "@components/SearchCollection";
import { filterByLang } from "@lib/i18n";
import { t } from "@lib/ui-strings";

const lang = "ko";

const prompts = filterByLang(
  (await getCollection("prompts")).filter((p) => !p.data.draft),
  lang
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [
  ...new Set(prompts.flatMap((p) => p.data.tags)),
].sort((a, b) => a.localeCompare(b));

const estimated_initial_size =
  28 + prompts.length * 158 + (prompts.length - 1) * 12;
---

<PageLayout title={t("page.prompts.title", lang)} description={t("page.prompts.desc", lang)}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {t("page.prompts.title", lang)}
      </h1>
      <div class="mt-1">
        {t("page.prompts.desc", lang)}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div
      id="search-collection-wrapper"
      class="animate"
      style={{ minHeight: `${estimated_initial_size}px` }}
    >
      <SearchCollection
        client:load
        entry_name={"prompts"}
        tags={tags}
        data={prompts}
        lang={lang}
      />
    </div>
  </BottomLayout>
</PageLayout>
