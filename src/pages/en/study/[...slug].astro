---
import { type CollectionEntry, getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro"
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro"
import { filterByLang, stripLangFromSlug } from "@lib/i18n"

export async function getStaticPaths() {
	const studies = await getCollection("study")
	return filterByLang(studies, "en").map((s) => ({
		params: { slug: stripLangFromSlug(s.slug) },
		props: s,
	}))
}

type Props = CollectionEntry<"study">
const study = Astro.props
const { title, summary } = study.data
---

<PageLayout title={title} description={summary}>
  <TopLayout>
    <div class="animate">
      <ArticleTopLayout entry={study} />
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <ArticleBottomLayout entry={study} />
    </div>
  </BottomLayout>
</PageLayout>
