---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import SearchCollection from "@components/SearchCollection";
import { filterByLang } from "@lib/i18n";
import { t } from "@lib/ui-strings";

const lang = "en";

const projects = filterByLang(
  (await getCollection("projects")).filter((project) => !project.data.draft),
  lang
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [...new Set(projects.flatMap((project) => project.data.tags))].sort(
  (a, b) => a.localeCompare(b),
);

const estimated_initial_size =
  28 + projects.length * 158 + (projects.length - 1) * 12;
---

<PageLayout title={t("page.projects.title", lang)} description={t("page.projects.desc", lang)}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {t("page.projects.title", lang)}
      </h1>
      <div class="mt-1">
        {t("page.projects.desc", lang)}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div id="search-collection-wrapper" class="animate" style={{ minHeight: `${estimated_initial_size}px` }}>
      <SearchCollection client:load entry_name={"projects"} tags={tags} data={projects} lang={lang} />
    </div>
  </BottomLayout>
</PageLayout>
