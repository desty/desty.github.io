---
import { type CollectionEntry, getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro"
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro"
import { filterByLang, stripLangFromSlug } from "@lib/i18n"

export async function getStaticPaths() {
	const guides = await getCollection("guides")
	return filterByLang(guides, "ko").map((guide) => ({
		params: { slug: stripLangFromSlug(guide.slug) },
		props: guide,
	}))
}

type Props = CollectionEntry<"guides">
const guide = Astro.props
const { title, summary } = guide.data
---

<PageLayout title={title} description={summary}>
  <TopLayout>
    <div class="animate">
      <ArticleTopLayout entry={guide} />
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <ArticleBottomLayout entry={guide} />
    </div>
  </BottomLayout>
</PageLayout>
