---
import { type CollectionEntry, getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro"
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro"

// Create the static guides pages
export async function getStaticPaths() {
	const guides = await getCollection("guides")
	return guides.map((guide) => ({
		params: { slug: guide.slug },
		props: guide,
	}))
}

// Get the requested guide
type Props = CollectionEntry<"guides">
const guide = Astro.props
const { title, summary } = guide.data
---

<PageLayout title={title} description={summary}>
  <TopLayout>
    <div class="animate">
      <ArticleTopLayout entry={guide} />
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <ArticleBottomLayout entry={guide} />
    </div>
  </BottomLayout>
</PageLayout>
