---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import SearchCollection from "@components/SearchCollection";
import { GUIDES } from "@consts";
import type { CollectionEntry } from "astro:content";

const guides = (await getCollection("guides"))
  .filter((guide) => !guide.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [
  ...new Set(guides.flatMap((guide) => guide.data.tags)),
].sort((a, b) => a.localeCompare(b));

const estimated_initial_size =
  28 + guides.length * 158 + (guides.length - 1) * 12;
---

<PageLayout title={GUIDES.TITLE} description={GUIDES.DESCRIPTION}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {GUIDES.TITLE}
      </h1>
      <div class="mt-1">
        {GUIDES.DESCRIPTION}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div
      id="search-collection-wrapper"
      class="animate"
      style={{ minHeight: `${estimated_initial_size}px` }}
    >
      <SearchCollection
        client:load
        entry_name={"guides"}
        tags={tags}
        data={guides}
      />
    </div>
  </BottomLayout>
</PageLayout>
